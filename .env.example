# Copy to .env and fill in. All values are OPTIONAL — the demo runs fully offline
# (the AI memo falls back to a deterministic template when no key is present).

# Anthropic API key for the AI Causal Memo. Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Model used for the memo. Defaults to a cheap, fast Claude model.
#   claude-haiku-4-5-20251001  (default, cheapest)
#   claude-opus-4-8            (best memo quality)
SYNTHLAUNCH_MODEL=claude-haiku-4-5-20251001
